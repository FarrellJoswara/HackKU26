# Shared Solana payer wallet used by every player to record their
# playthrough summary on chain via the SPL Memo program.
#
# Provision automatically:
#
#   npm run solana:setup
#
# That script generates a fresh keypair (or reuses the one already in
# .env.local), tops it up via the public faucet, and writes both
# variables below into .env.local for you. Vite picks them up at dev /
# build time via `import.meta.env`.
#
# This wallet only ever holds testnet/devnet "play" SOL — never real
# funds. Even so, never commit a populated .env.local; it's already in
# .gitignore.

# 64-byte secret key as a JSON array of integers (the format
# `Keypair.secretKey` serializes to). Example:
#   VITE_SOLANA_PAYER_SECRET=[12,34,56,...,78]
VITE_SOLANA_PAYER_SECRET=

# Which Solana cluster the wallet is funded on. The setup script will
# pick `testnet` if its faucet cooperates, otherwise `devnet`.
# Allowed values: testnet | devnet
VITE_SOLANA_CLUSTER=testnet
